{
  "manifest_version": 3,
  "name": "Student Banner Disabler",
  "version": "1.0",
  "description": "This disables the student de-activation message on Scratch.",
  "permissions": [
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://scratch.mit.edu/*",
    "https://*.scratch.mit.edu/*",
    "https://scratch.org/*",
    "https://*.scratch.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["site-css/*.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
