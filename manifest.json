{
  "manifest_version": 3,
  "name": "Student Banner Disabler",
  "version": "1.0",
  "description": "This disables the student de-activation message on Scratch.",
  "permissions": [
    "scripting",
    "tabs"
  ],
  "action": {
    "default_popup": "www/popup/popup.html"
  },
  "host_permissions": [
    "https://scratch.mit.edu/*",
    "https://*.scratch.mit.edu/*",
    "https://scratch.org/*",
    "https://*.scratch.org/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://scratch.mit.edu/*",
        "https://*.scratch.mit.edu/*",
        "https://scratch.org/*",
        "https://*.scratch.org/*"
      ],
      "css": ["site-css/components.css"],
      "js": ["site-js/components.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["site-css/*.css", "site-js/*.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
