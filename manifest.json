{
  "manifest_version": 3,
  "name": "Student Banner Disabler",
  "version": "1.0",
  "description": "This disables the student de-activation message on Scratch.",
  "content_scripts": [
    {
      "matches": [
        "https://scratch.mit.edu",
        "https://scratch.mit.edu/*",
        "https://*.scratch.mit.edu/*",
        "https://scratch.org",
        "https://scratch.org/*",
        "https://*.scratch.org/*"
      ],
      "css": ["imports.css"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["site-css/*.css"],
      "matches": [
        "https://scratch.mit.edu",
        "https://scratch.mit.edu/*",
        "https://*.scratch.mit.edu/*",
        "https://scratch.org/*",
        "https://scratch.org",
        "https://*.scratch.org/*"
      ]
    }
  ]
}
